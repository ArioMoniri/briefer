# =====================================================================
# Briefer configuration.  Copy to `.env` and fill in.  `setup.sh` runs
# an interactive wizard that generates this file for you.
#
# SECURITY: `.env` holds secrets. It is git-ignored and setup.sh chmods
# it to 600. Never commit it, never paste it into a chat.
# =====================================================================

# --- Telegram -------------------------------------------------------
# Token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric chat IDs allowed to use the bot.
# Everyone else is silently ignored. Get your id from @userinfobot.
# Leave empty ONLY during first setup; the bot refuses to serve an
# empty allowlist unless BRIEFER_BOOTSTRAP=1 (see below).
# You can also add more chats later at runtime with /allow <id> — no
# restart needed.
ALLOWED_CHAT_IDS=

# Admin chats that may run /allow, /deny and /allowlist. Defaults to
# ALLOWED_CHAT_IDS when left blank.
ADMIN_CHAT_IDS=

# Shared login password. A chat must /login with this once per session
# (in addition to being on the allowlist). Stored here in plain text on
# a 600 file; the running bot only keeps a salted hash in memory.
LOGIN_PASSWORD=

# Bootstrap mode: set to 1 for the very first run so you can discover
# your own chat id via /whoami, then add it to ALLOWED_CHAT_IDS and set
# this back to 0. Never leave this at 1 in production.
BRIEFER_BOOTSTRAP=0

# --- Anthropic (summaries, extraction, verification) ----------------
ANTHROPIC_API_KEY=
# Model used for the first-pass analysis.
ANTHROPIC_MODEL=claude-sonnet-5
# Model used for the independent verification pass (should be at least
# as capable as ANTHROPIC_MODEL).
ANTHROPIC_VERIFY_MODEL=claude-opus-4-8

# --- Google Sheets --------------------------------------------------
# How the bot authenticates to Google: "oauth" (log in with your own
# Google account; sheets live in YOUR Drive) or "service_account".
# For oauth, run `./manage.sh google-auth` once — it prints a login link
# you open on your phone/laptop (the server needs no browser).
GOOGLE_AUTH_MODE=oauth
# OAuth mode: a "Desktop app" OAuth client JSON from Google Cloud, plus
# the token file the login writes.
GOOGLE_OAUTH_CLIENT_FILE=client_secret.json
GOOGLE_TOKEN_FILE=token.json
# Service-account mode: path to the service-account JSON key. Share BOTH
# sheets with its client_email as Editor.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Spreadsheet IDs (the long id in the sheet URL). Leave blank to have
# the bot create them on first run and print the ids to add here.
ARTICLES_SHEET_ID=
EVENTS_SHEET_ID=

# --- Company context (drives the "where can we use this" analysis) --
COMPANY_NAME=Vivax
COMPANY_URL=https://getvivax.com
COMPANY_FOCUS=Medical AI, medical education, clinical simulation, and operating-room intelligence ("Reality Motors"). We build AI that powers realistic clinical training and surgical/OR decision support.

# --- Media: X/Twitter + video/audio transcription -------------------
# X (Twitter) API — OPTIONAL. Briefer reads tweets without any keys via a
# no-auth fallback, so these only add robustness IF you're on a paid X tier
# (the Free tier can't read tweets; lookups 403 and we fall back anyway).
# Provide EITHER a ready bearer token, OR your consumer key + secret (aka
# "API Key" + "API Key Secret") and Briefer mints the bearer itself.
TWITTER_BEARER_TOKEN=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
# Video/audio transcription (uploads + YouTube/X/TikTok links) with a local
# Whisper model. ffmpeg + Whisper are pip-installed inside the venv, so no
# system packages are touched. Set to 0 to skip (saves CPU + a model download).
ENABLE_TRANSCRIPTION=1
# Whisper model size: tiny | base | small | medium (bigger = better + slower).
WHISPER_MODEL=base
# Skip transcription for videos longer than this (seconds).
TRANSCRIPTION_MAX_SECONDS=1800
# Max bytes to download from a video link for transcription.
MEDIA_MAX_BYTES=50000000
# Keyframes per video sent to the Anthropic multimodal model (0 = off).
VIDEO_KEYFRAMES=4
# Fallback image downloader (gallery-dl) for photo posts (Instagram, galleries).
ENABLE_GALLERY_DL=1
# Headless-browser fallback (Playwright) for pages that return no text to a
# plain fetch (LinkedIn, JS SPAs). No-op until installed: ./manage.sh enable-browser
ENABLE_BROWSER_FALLBACK=1

# --- Behaviour ------------------------------------------------------
# Max size (bytes) of any downloaded file/link body we will process.
MAX_DOWNLOAD_BYTES=15000000
# Per-chat message rate limit (messages per minute).
RATE_LIMIT_PER_MINUTE=20
# How many hours before a deadline to poke you. Comma-separated.
DEADLINE_REMINDER_HOURS=72,24,3
# Timezone for reminders and timestamps (IANA name).
TIMEZONE=Europe/Istanbul
# Directory for local state (sqlite, temp downloads, logs).
DATA_DIR=data
LOG_LEVEL=INFO
